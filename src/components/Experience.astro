---
import ExperienceItem from "./ExperienceItem.astro"

const EXPERIENCE = [
  {
    date: "2024 — Present",
    title: "Full Stack Engineer · Chicksgold",
    description:
      "Designing and developing scalable backend services and APIs using C#, .NET 8, ASP.NET Core, and MySQL for a high-traffic digital marketplace. Built RESTful APIs and transactional systems supporting secure financial workflows, optimized database queries for high-volume transactions, and contributed to cloud deployments and CI/CD pipelines across AWS and Azure.",
    link: "https://chicksgold.com"
  },
  {
    date: "2024",
    title: "Full Stack Developer · MTS Group",
    description:
      "Developed backend services and APIs using Python and Django for scalable web applications. Designed optimized MySQL schemas, implemented authentication and authorization systems, and deployed cloud infrastructure using AWS (EC2, S3) to support reliable production environments.",
  },
  {
    date: "2024",
    title: "Full Stack Developer · Dream Junk Studios",
    description:
      "Developed backend APIs and platform services using Node.js, Express, and TypeScript supporting user management and core platform functionality. Improved API performance through optimized queries and backend architecture while maintaining PostgreSQL data reliability.",
  },
  {
    date: "2023 — 2024",
    title: "Backend Developer · Argatio",
    description:
      "Migrated legacy applications to a Node.js microservices architecture improving scalability and maintainability. Designed relational and document data models using MySQL and MongoDB and implemented REST APIs supporting internal services and external integrations.",
    link: "http://argatio.com/"
  }
];
---
<ol class="relative border-s border-gray-200 ml-3">
  {
    EXPERIENCE.map(experience => (
    <li class="mb-10 ms-4">
      <ExperienceItem {...experience} />
    </li>
    ))
  }
</ol>

