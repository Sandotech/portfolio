---
const { target, rel, download, ...anchorProps } = Astro.props

const isDownload = download !== undefined && download !== false
const resolvedTarget = isDownload ? target : (target ?? '_blank')
const resolvedRel = resolvedTarget ? (rel ?? 'noopener noreferrer') : rel
---

<a 
    class={`
    bg-white/5
    border border-white/10 rounded-full
    flex justify-center items-center gap-x-2
    py-1 px-2 md:py-2 md:px-4
    text-xs md:text-base
    transition
    hover:scale-110 hover:bg-white/10`}
    {...anchorProps}
    download={download}
    target={resolvedTarget}
    rel={resolvedRel}
    >
    <slot />
</a>